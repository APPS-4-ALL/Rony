# Normalize line endings: store LF in the repo, check out native per-OS.
# Eliminates the cross-OS CRLF/LF churn (and the prettier "Delete ␍" warnings).
* text=auto eol=lf

# Scripts that must stay CRLF on Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch line endings
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
*.woff binary
*.woff2 binary
