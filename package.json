{
  "name": "roni-invoices",
  "version": "1.0.0",
  "description": "Local-first desktop app to scan, download, and manage invoices and receipts from Gmail.",
  "main": "./out/main/index.js",
  "author": "apps4all",
  "homepage": "https://github.com/shbh8205-lgtm/invoice-scanner-rony",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "ai:try": "tsx scripts/try-ai.ts",
    "icon:round": "node scripts/round-icon.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@napi-rs/canvas": "^0.1.100",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.10",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "jimp": "^1.6.1",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.60.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.8",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  }
}
