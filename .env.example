# Google OAuth 2.0 — Desktop app client (RONY-6)
#
# Create these at https://console.cloud.google.com :
#   1. Create/select a project.
#   2. APIs & Services → Enable APIs → enable "Gmail API".
#   3. APIs & Services → OAuth consent screen → External → add your Google
#      account under "Test users" (keeps you out of the verification queue).
#   4. APIs & Services → Credentials → Create credentials → OAuth client ID
#      → Application type: "Desktop app".
#   5. Copy the Client ID and Client secret below.
#
# Then: copy this file to ".env" (which is gitignored) and fill in real values.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ---------------------------------------------------------------------------
# Advanced AI scan engine (RONY-10)
#
# Choose ONE provider and set its API key. Default is "openai" when unset.
#   - OpenAI key:  https://platform.openai.com/api-keys
#   - Gemini key:  https://aistudio.google.com/apikey
#   - Claude key:  https://console.anthropic.com/settings/keys
#   - Groq key:    https://console.groq.com/keys
# Then run `npm run ai:try` to do a live classification of a sample email.
# ---------------------------------------------------------------------------

# One of: openai | gemini | claude | groq
AI_PROVIDER=openai

# Used when AI_PROVIDER=openai
OPENAI_API_KEY=
# Optional model override (default: gpt-4o)
OPENAI_MODEL=

# Used when AI_PROVIDER=gemini
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-pro)
GEMINI_MODEL=

# Used when AI_PROVIDER=claude (Anthropic)
ANTHROPIC_API_KEY=
# Optional per-tier model overrides (defaults: fast claude-haiku-4-5, strong claude-opus-4-8)
ANTHROPIC_MODEL_FAST=
ANTHROPIC_MODEL_STRONG=

# Used when AI_PROVIDER=groq (text-only — fast/cheap classifier, no PDF/image reading)
GROQ_API_KEY=
# Optional per-tier model overrides (defaults: fast llama-3.1-8b-instant, strong llama-3.3-70b-versatile)
GROQ_MODEL_FAST=
GROQ_MODEL_STRONG=
